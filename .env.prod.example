# ============================================================
# AI Calendar — production environment template.
# Copy to .env.prod and fill in. NEVER commit .env.prod.
# ============================================================

# ===== Core =====
ENV=production
LOG_LEVEL=INFO

# ⚠ MUST be different from dev. Generate via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ===== Domain (used by Caddy + Clerk + Telegram) =====
DOMAIN=example.com
ACME_EMAIL=you@example.com

# ===== Postgres =====
POSTGRES_USER=ai_calendar
# ⚠ Strong password, random. `openssl rand -hex 24` works.
POSTGRES_PASSWORD=
POSTGRES_DB=ai_calendar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ai_calendar:${POSTGRES_PASSWORD}@postgres:5432/ai_calendar

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Auth (Clerk — PRODUCTION instance) =====
# In Clerk Dashboard → Create application → switch to "Production" instance.
# Production instance requires a verified domain (Clerk shows you DNS records
# to add). Once verified, copy pk_live_… / sk_live_… here.
AUTH_PROVIDER=clerk
NEXT_PUBLIC_AUTH_PROVIDER=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_JWKS_URL=https://clerk.${DOMAIN}/.well-known/jwks.json
CLERK_ISSUER=https://clerk.${DOMAIN}

# ===== Frontend =====
# Important: web is on the same domain as backend, so /api goes through Caddy.
NEXT_PUBLIC_API_BASE_URL=https://${DOMAIN}
# Not used in prod (kept for type safety only):
NEXT_PUBLIC_DEV_USER_EMAIL=

# ===== LLM =====
# Use whichever provider you want. Yandex Cloud LLM is the most natural fit
# since the host VM is already in YC.
LLM_PROVIDER=yandex
LLM_MODEL=qwen3-235b-a22b-fp8/latest
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Optional fallbacks:
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_API_KEY=

# ===== Telegram bot (webhook mode) =====
TELEGRAM_BOT_TOKEN=
TG_BOT_USERNAME=
# `openssl rand -hex 32`
INTERNAL_SERVICE_TOKEN=
TG_BOT_PUSH_URL=http://tg-bot:8001

# Webhook mode — recommended in prod. URL must be HTTPS and resolvable from
# api.telegram.org. Caddy proxies /telegram/webhook → tg-bot:8002.
TG_BOT_MODE=webhook
TG_WEBHOOK_URL=https://${DOMAIN}/telegram/webhook
# Shared secret Telegram includes in every webhook call; aiogram verifies it.
# `openssl rand -hex 24`
TG_WEBHOOK_SECRET=
TELEGRAM_LINK_TTL_MINUTES=10

# Voice → text via Yandex SpeechKit. Reuses YANDEX_API_KEY/FOLDER_ID above.
STT_PROVIDER=yandex
STT_LANGUAGE=ru-RU
STT_MAX_VOICE_SECONDS=30

# ===== Observability (optional but recommended) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
SENTRY_DSN=

# ===== Whoop =====
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://${DOMAIN}/api/integrations/whoop/callback
WHOOP_SCOPES=offline read:recovery read:sleep read:workout read:cycles read:profile

# ===== Backups → Yandex Object Storage =====
# In Yandex Cloud Console:
#   1. Object Storage → Create bucket (e.g. "ai-calendar-backups", private).
#   2. IAM → Service accounts → create "backup-uploader" with role
#      "storage.editor" scoped to the bucket.
#   3. Service account → Create static key → copy both values here.
BACKUP_BUCKET=ai-calendar-backups
BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net
BACKUP_S3_REGION=ru-central1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# Keep daily backups for N days, then delete (handled by lifecycle rule on
# the bucket OR by scripts/backup.sh — see deploy/README.md).
BACKUP_RETAIN_DAYS=14
