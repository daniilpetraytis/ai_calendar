# ===== Core =====
ENV=development
LOG_LEVEL=INFO

# Where to bind web (3000) and backend (8000) ports.
# 127.0.0.1 = only loopback (safe default; works with SSH tunnel).
# 0.0.0.0   = expose to the whole internet — DO NOT do this until
#             AUTH_PROVIDER != dev AND you understand the risks.
# Postgres and Redis are ALWAYS bound to 127.0.0.1, regardless.
BIND_HOST=127.0.0.1

# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-me-with-fernet-key

# ===== Postgres =====
POSTGRES_USER=ai_calendar
POSTGRES_PASSWORD=ai_calendar
POSTGRES_DB=ai_calendar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ai_calendar:ai_calendar@postgres:5432/ai_calendar

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Auth =====
# "clerk" -> production-ready: verifies Clerk-issued JWTs against CLERK_JWKS_URL.
# "dev"   -> trusts X-Dev-User-Email header (for curl/test scripts only — the
#            web app expects Clerk regardless because <ClerkProvider> is always
#            mounted in layout.tsx).
AUTH_PROVIDER=clerk

# How to set Clerk up (5 minutes):
# 1. https://dashboard.clerk.com → Create application. Pick the providers you
#    want (email/password, Google, GitHub, etc.) — Clerk renders the UI.
# 2. Copy the Publishable Key (starts with `pk_`) into
#    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY below.
# 3. Copy the Secret Key (starts with `sk_`) into CLERK_SECRET_KEY below. The
#    backend uses it to fetch the user's email from Clerk's API (Clerk's
#    default short session token doesn't carry email).
# 4. Click "JWKS URL" in the API Keys section of the dashboard and paste it
#    into CLERK_JWKS_URL. CLERK_ISSUER (the part before /.well-known) is
#    optional but recommended for stricter verification.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=

# ===== LLM =====
# Pick ONE provider. Default = google (free tier, easiest signup at https://aistudio.google.com).
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-pro

# google: get a key at https://aistudio.google.com (for Gemini LLM)
GOOGLE_API_KEY=

# anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5-20250929

# openai (https://platform.openai.com)
OPENAI_API_KEY=
# Custom OpenAI-compatible endpoint (Ollama, Together, Fireworks, vLLM ...)
OPENAI_BASE_URL=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5

# openrouter (https://openrouter.ai) — single key, any model
OPENROUTER_API_KEY=
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4.5
# LLM_MODEL=deepseek/deepseek-chat
# LLM_MODEL=google/gemini-2.5-pro

# yandex AI Studio (https://yandex.cloud → AI Studio).
# 1. Create a Folder in Yandex Cloud Console; copy its ID (starts with b1g...).
# 2. Create an API key with scope `yc.ai.languageModels.execute`; copy the secret.
# 3. Pay in roubles. Tool-calling supported on yandexgpt/rc, qwen3, gpt-oss.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# LLM_PROVIDER=yandex
# LLM_MODEL=yandexgpt/rc                          # YandexGPT Pro 5.1, RU-friendly
# LLM_MODEL=qwen3-235b-a22b-fp8/latest            # сильнейший для tool-calling, 262K context
# LLM_MODEL=gpt-oss-120b/latest                   # OpenAI OSS, хороший reasoning
# LLM_MODEL=gemma-3-27b-it/latest                 # Google open model
# LLM_MODEL=yandexgpt-lite/latest                 # быстрая, дешёвая

# ===== Agent runtime budgets =====
# Per-LLM-request timeout (passed to the underlying client).
LLM_REQUEST_TIMEOUT_SECONDS=30
# Max LLM↔tool round-trips inside a single chat turn.
AGENT_RECURSION_LIMIT=16
# Hard wall-clock budget for one chat turn end-to-end. If exceeded, the chat
# stream emits an `error` event instead of hanging forever.
AGENT_TOTAL_TIMEOUT_SECONDS=90

# ===== Whoop OAuth (Phase D) =====
# 1. Sign up at https://developer-dashboard.whoop.com → New App
# 2. Add redirect: http://localhost:8000/api/integrations/whoop/callback
# 3. Whitelist your Whoop email under "Test Users" until the app is approved.
# `offline` scope is REQUIRED so we get a refresh token (Whoop access tokens
# live ~1h).
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/api/integrations/whoop/callback
WHOOP_SCOPES=offline read:recovery read:sleep read:workout read:cycles read:profile
# When to send morning recovery push. Earliest is a guard against very-early
# Whoop publish times (some users see recovery at 04:30); latest is the
# cutoff past which we skip the push for the day.
MORNING_PUSH_MIN_LOCAL_HOUR=7
MORNING_PUSH_MAX_LOCAL_HOUR=11
# Buffer after the user's last event of the day before we ping
# "how was your day" (so we don't ask while still in the meeting).
EVENING_PROMPT_AFTER_LAST_EVENT_MINUTES=30
# Hard latest hour for the evening prompt (we never wake people up).
EVENING_PROMPT_MAX_LOCAL_HOUR=23
# Fallback hour to ask on days where the calendar is empty.
EVENING_PROMPT_FALLBACK_LOCAL_HOUR=21
# Whoop workout ↔ sport-event match window (minutes).
WHOOP_WORKOUT_EVENT_MATCH_WINDOW_MINUTES=60

# ===== Frontend =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_PROVIDER=clerk
# Only used when NEXT_PUBLIC_AUTH_PROVIDER=dev (and the matching
# AUTH_PROVIDER=dev on the backend) — sends X-Dev-User-Email for CLI/curl.
NEXT_PUBLIC_DEV_USER_EMAIL=demo@example.com

# ===== Telegram bot (Phase B) =====
# Step-by-step setup:
# 1. Talk to @BotFather in Telegram → /newbot → copy the token here.
# 2. Set bot username in @BotFather, paste it (WITHOUT the @) into TG_BOT_USERNAME.
# 3. Generate a strong shared secret:
#       python -c "import secrets; print(secrets.token_urlsafe(32))"
#    Paste it into BOTH INTERNAL_SERVICE_TOKEN below.
# 4. Start the bot:  docker compose --profile telegram up tg-bot
# 5. In web → Settings → Telegram → Connect, then open the deep link.

TELEGRAM_BOT_TOKEN=
TG_BOT_USERNAME=
# Shared secret for backend ↔ tg-bot S2S calls. Same value goes into BOTH services.
INTERNAL_SERVICE_TOKEN=
# Backend → bot push channel. In docker-compose this default works as-is.
TG_BOT_PUSH_URL=http://tg-bot:8001
# polling = bot pulls Telegram (works behind NAT, good for dev/local prod).
# webhook = Telegram pushes to TG_WEBHOOK_URL (needs public HTTPS).
TG_BOT_MODE=polling
TG_WEBHOOK_URL=
TG_WEBHOOK_SECRET=
# Deep-link tokens expire after this many minutes.
TELEGRAM_LINK_TTL_MINUTES=10

# Voice messages → text. "yandex" reuses YANDEX_API_KEY + YANDEX_FOLDER_ID.
# "off" disables voice handling. Yandex SpeechKit v1 caps at 30s / 1 MB per voice.
STT_PROVIDER=yandex
STT_LANGUAGE=ru-RU
STT_MAX_VOICE_SECONDS=30

# ===== Observability (optional) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
SENTRY_DSN=
